  "keyFeatures": [
    "High-performance Git RPC service using gRPC protocol",
    "Horizontal scaling and fault-tolerant storage via Praefect",
    "Comprehensive repository operations (clone, push, pull, merge)",
    "Built-in caching and backpressure mechanisms",
    "High availability with automatic replication and failover",
    "Object pooling for efficient repository storage",
    "Distributed tracing and Prometheus monitoring",
    "Transaction support for consistent multi-node writes"
  ],
  "publicApiSurface": [
    "BlobService - GetBlob, GetBlobs, ListBlobs, ListAllBlobs, GetLFSPointers",
    "CommitService - ListCommits, FindCommit, CommitStats, GetTreeEntries",
    "RepositoryService - CreateRepository, RepositoryExists, GarbageCollect, RepositorySize",
    "RefService - FindAllBranches, FindAllTags, CreateBranch, DeleteRefs",
    "OperationsService - UserCreateBranch, UserMergeToRef, UserCommitFiles",
    "RemoteService - AddRemote, FetchInternalRemote, UpdateRemoteMirror",
    "SmartHTTPService - InfoRefsUploadPack, PostUploadPack, PostReceivePack",
    "SSHService - SSHUploadPack, SSHReceivePack, SSHUploadArchive",
    "DiffService - CommitDiff, CommitDelta, RawDiff, RawPatch",
    "ConflictsService - ListConflictFiles, ResolveConflicts",
    "CleanupService - ApplyBfgObjectMapStream",
    "NamespaceService - AddNamespace, RemoveNamespace, RenameNamespace",
    "ObjectPoolService - CreateObjectPool, LinkRepositoryToObjectPool",
    "HookService - PreReceiveHook, PostReceiveHook, UpdateHook",
    "WikiService - WikiWritePage, WikiUpdatePage, WikiFindPage",
    "ServerService - ServerInfo, DiskStatistics",
    "PraefectInfoService - RepositoryReplicas, Dataloss"
  ]
}
